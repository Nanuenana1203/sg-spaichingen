import { NextResponse } from "next/server";
import bcrypt from "bcryptjs";
// Pfad zur Client-Datei: Projektwurzel/lib/supabaseClient.ts
import { supabase } from "../../../src/lib/supabaseClient";

export async function POST(req: Request) {
  try {
    const { name, password } = await req.json();

    if (!name || !password) {
      return NextResponse.json({ ok: false, msg: "Fehlende Felder" }, { status: 400 });
    }

    // Nutzer laden
    const { data: user, error } = await supabase
      .from("benutzer")
      .select("id,name,kennwort,istadmin")
      .eq("name", name)
      .single();

    if (error || !user) {
      return NextResponse.json({ ok: false, msg: "Ungültig" }, { status: 401 });
    }

    // Passwort prüfen (DB-Feld 'kennwort' enthält den bcrypt-Hash)
    const ok = await bcrypt.compare(password, user.kennwort);
    if (!ok) {
      return NextResponse.json({ ok: false, msg: "Ungültig" }, { status: 401 });
    }

    // Session-Cookie setzen
    const resp = NextResponse.json({ ok: true, user: { id: user.id, name: user.name, istadmin: user.istadmin } }, { status: 200 });
    resp.cookies.set("sgs_session", JSON.stringify({ id: user.id, name: user.name, istadmin: user.istadmin }), {
      httpOnly: true,
      secure: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 8,
      path: "/",
    });
    return resp;
  } catch (e: any) {
    return NextResponse.json({ ok: false, msg: "SERVER", detail: String(e?.message ?? e) }, { status: 500 });
  }
}
