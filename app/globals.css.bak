@tailwind base;
@tailwind components;
@tailwind utilities;

/* === Reusable UI helpers (nur echte Tailwind-Utilities!) === */
.label { @apply block text-sm font-medium text-slate-700; }
.input { @apply w-full rounded-md border px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500; }

.btn { @apply inline-flex items-center justify-center px-3 py-2 rounded-md border text-sm font-medium transition; }
.btn-primary { @apply bg-blue-600 text-white border-blue-600 hover:bg-blue-700; }
.btn-ghost { @apply bg-transparent hover:bg-gray-100; }

/* Kleinzeug für Kalender/Boxen */
.card { @apply rounded-2xl border shadow bg-white; }
